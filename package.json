{
  "name": "aria-video-editor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "native:build": "node-gyp rebuild",
    "native:configure": "node-gyp configure",
    "electron:dev": "concurrently \"vite --mode development\" \"wait-on http://localhost:5174 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "start": "npm run electron:dev"
  },
  "dependencies": {
    "bindings": "^1.5.0",
    "lucide-vue-next": "^0.344.0",
    "node-addon-api": "^8.9.0",
    "pinia": "^2.1.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^10.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^9.0.10"
  }
}
